# Conexión a tu clúster de MongoDB Atlas (Requerido)
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/qrflow?retryWrites=true&w=majority

# API Key de Resend para enviar correos (Opcional, si no se provee se guardará el mail localmente en scratch/last-email.html)
RESEND_API_KEY=YOUR_RESEND_API_KEY

# Configuración SMTP/Gmail opcional (Alternativa a Resend para enviar a cualquier usuario sin dominio verificado)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password
